# =============================================================================
# AppDynamics MCP Server — Single-User Mode Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Controller credentials
# -----------------------------------------------------------------------------
# One pair per controller. Env var names are derived from the controller
# "name" field in controllers.json (uppercased):
#   name: "production" → APPDYNAMICS_PRODUCTION_CLIENT_ID / _CLIENT_SECRET
#   name: "staging"    → APPDYNAMICS_STAGING_CLIENT_ID / _CLIENT_SECRET
#
# Create an OAuth2 API Client in AppDynamics:
#   Controller → Settings → Administration → API Clients → + Create
#   Grant: "Account Owner" or equivalent admin role
# -----------------------------------------------------------------------------

APPDYNAMICS_PRODUCTION_CLIENT_ID=your-oauth2-client-id
APPDYNAMICS_PRODUCTION_CLIENT_SECRET=your-oauth2-client-secret

# Add entries for each additional controller:
# APPDYNAMICS_STAGING_CLIENT_ID=your-staging-client-id
# APPDYNAMICS_STAGING_CLIENT_SECRET=your-staging-client-secret

# -----------------------------------------------------------------------------
# Transport
# -----------------------------------------------------------------------------
# stdio          — Claude Desktop (default)
# sse            — HTTP/SSE (browser or shared deployment)
# streamable-http — Cursor
# MCP_TRANSPORT=stdio

# -----------------------------------------------------------------------------
# K8s liveness probe / Prometheus metrics
# -----------------------------------------------------------------------------
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080

# -----------------------------------------------------------------------------
# Persistent disk cache
# -----------------------------------------------------------------------------
DISKCACHE_DIR=data/diskcache
DISKCACHE_SIZE_LIMIT_GB=2

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# APPD_MCP_DEBUG=false
