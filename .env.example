# =============================================================================
# AppDynamics MCP Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Vault mode
# -----------------------------------------------------------------------------
# "mock" (default): reads credentials directly from env vars below.
# "hashicorp": fetches credentials from HashiCorp Vault at VAULT_ADDR.
VAULT_MODE=mock

# HashiCorp Vault connection (only required when VAULT_MODE=hashicorp)
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=hvs.your-vault-token-here
# VAULT_NAMESPACE=  # Vault Enterprise namespace (optional)

# -----------------------------------------------------------------------------
# Controller credentials (mock / dev mode)
# -----------------------------------------------------------------------------
# Env var names are derived from vaultPath in controllers.json by stripping
# the "secret/" prefix and replacing "/" with "_" (uppercase):
#   "vaultPath": "secret/appdynamics/production"
#   → APPDYNAMICS_PRODUCTION_CLIENT_ID
#   → APPDYNAMICS_PRODUCTION_CLIENT_SECRET
#
# Replace "PRODUCTION" with the uppercased, underscore-separated segments of
# your vaultPath for each controller you have configured.

# Data account — VIEW-level, used for all operational API calls (metrics, snapshots, BTs, etc.)
APPDYNAMICS_PRODUCTION_CLIENT_ID=your-oauth2-client-id
APPDYNAMICS_PRODUCTION_CLIENT_SECRET=your-oauth2-client-secret

# RBAC account — admin read-only, used ONLY for user/role/group lookups.
# Requires Account Owner or equivalent read-only admin privilege on the controller.
# Vault path: secret/appdynamics/production/rbac → env vars below.
APPDYNAMICS_PRODUCTION_RBAC_CLIENT_ID=your-rbac-admin-client-id
APPDYNAMICS_PRODUCTION_RBAC_CLIENT_SECRET=your-rbac-admin-client-secret

# Add entries for each additional controller:
# APPDYNAMICS_STAGING_CLIENT_ID=your-staging-client-id
# APPDYNAMICS_STAGING_CLIENT_SECRET=your-staging-client-secret
# APPDYNAMICS_STAGING_RBAC_CLIENT_ID=your-staging-rbac-client-id
# APPDYNAMICS_STAGING_RBAC_CLIENT_SECRET=your-staging-rbac-client-secret

# -----------------------------------------------------------------------------
# RBAC app-access cache TTL
# -----------------------------------------------------------------------------
# How long (seconds) a user's resolved app set is cached before re-fetching
# from AppD RBAC. Default: 86400 (1 day). Options:
#   1800   — session-scoped (fast propagation, more RBAC API calls)
#   86400  — daily (recommended for most orgs)
#   604800 — weekly (large stable orgs with infrequent RBAC changes)
# APPDYNAMICS_RBAC_CACHE_TTL_S=86400

# -----------------------------------------------------------------------------
# K8s liveness probe HTTP server
# -----------------------------------------------------------------------------
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080

# -----------------------------------------------------------------------------
# Persistent disk cache
# -----------------------------------------------------------------------------
DISKCACHE_DIR=data/diskcache
# Maximum disk cache size in gigabytes
DISKCACHE_SIZE_LIMIT_GB=2

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Audit log and startup messages are written to stderr.
# Set to "true" to enable verbose debug output.
# APPD_MCP_DEBUG=false

# -----------------------------------------------------------------------------
# Audit log file persistence
# -----------------------------------------------------------------------------
# Directory where daily JSONL audit logs are written (one file per UTC day).
# Format: audit/YYYY-MM-DD.jsonl — each line is a JSON audit entry.
# Default: "audit" (relative to working directory). Set to an absolute path
# in production (e.g. /var/log/appdynamics-mcp).
# AUDIT_LOG_DIR=audit
